import {
  "moonbit-community/imgui/bindings" @bindings,
  "moonbitlang/core/encoding/utf8" @encoding/utf8,
}

import {
  "moonbitlang/core/debug" @debug,
} for "test"

supported_targets = "+native"

options(
  link: {
    "native": {
      "cc": "cc",
      "cc-flags": "-Wno-deprecated-declarations -Ibindings/dear_bindings -Ibindings/upstream/imgui -Ibindings/upstream/imgui/backends",
      "cc-link-flags": "-lstdc++",
    },
  },
)
