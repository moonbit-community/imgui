supported_targets = "+native"

options(
  link: {
    "native": {
      "stub-cc": "c++",
      "stub-cc-flags": "-fno-exceptions -fno-rtti -fno-threadsafe-statics -Wno-deprecated-declarations -Ibindings -Ibindings/upstream/imgui -Ibindings/upstream/imgui/backends -Ibindings/upstream/imgui/examples/libs/glfw/include",
    },
  },
  "native-stub": [
    "imgui_impl_glfw.cpp",
    "dcimgui_impl_glfw.cpp",
    "generated_runtime.cpp",
  ],
)
