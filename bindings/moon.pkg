supported_targets = "+native"

options(
  link: {
    "native": {
      "stub-cc": "c++",
      "stub-cc-flags": "-fno-exceptions -fno-rtti -fno-threadsafe-statics -Wno-deprecated-declarations -I. -Iupstream/imgui -Iupstream/imgui/backends",
    },
  },
  "native-stub": [
    "upstream/imgui/imgui.cpp",
    "upstream/imgui/imgui_demo.cpp",
    "upstream/imgui/imgui_draw.cpp",
    "upstream/imgui/imgui_tables.cpp",
    "upstream/imgui/imgui_widgets.cpp",
    "dcimgui.cpp",
    "generated_runtime.cpp",
  ],
)
