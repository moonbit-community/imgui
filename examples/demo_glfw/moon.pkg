import {
  "moonbit-community/imgui" @imgui,
  "moonbit-community/imgui/backend/glfw_opengl3" @backend,
  "moonbit-community/imgui/raw" @raw,
}

supported_targets = "+native"

options(
  link: {
    "native": {
      "cc": "cc",
      "cc-flags": "-Wno-deprecated-declarations -Iraw/upstream/imgui -Iraw/upstream/imgui/backends -Iimgui/raw/upstream/imgui -Iimgui/raw/upstream/imgui/backends",
      "cc-link-flags": "-lglfw -lGL -ldl -lpthread -lstdc++",
    },
  },
  "is-main": true,
)
